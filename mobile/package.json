{
  "name": "nyxid-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "EXPO_PUBLIC_DEV_MODE=true expo start",
    "android": "EXPO_PUBLIC_DEV_MODE=true expo run:android",
    "ios": "EXPO_PUBLIC_DEV_MODE=true expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "bump:android:build": "sh scripts/bump-android-build.sh",
    "build:ios": "EXPO_PUBLIC_API_BASE_URL=https://nyx-api.chrono-ai.fun/api/v1 expo run:ios --configuration Release",
    "bump:ios:build": "sh scripts/bump-ios-build.sh",
    "build:ios:testflight": "pnpm run bump:ios:build && grep -q 'EXPO_PUBLIC_API_BASE_URL' ios/.xcode.env.local 2>/dev/null || echo 'export EXPO_PUBLIC_API_BASE_URL=https://nyx-api.chrono-ai.fun/api/v1' >> ios/.xcode.env.local && xcodebuild -workspace ios/NyxIDMobile.xcworkspace -scheme NyxIDMobile -configuration Release -destination 'generic/platform=iOS' -archivePath ios/build/NyxIDMobile.xcarchive -allowProvisioningUpdates archive",
    "eas-build-post-install": "node scripts/patch-android-build-gradle.js"
  },
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      }
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^14.1.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.16",
    "@tanstack/react-query": "^5.90.20",
    "expo": "~53.0.0",
    "expo-blur": "~14.1.5",
    "expo-clipboard": "~7.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-notifications": "~0.31.0",
    "expo-secure-store": "~14.2.0",
    "expo-status-bar": "~2.2.3",
    "expo-task-manager": "~13.1.6",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-hook-form": "^7.71.1",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-gifted-chat": "^3.3.2",
    "react-native-reanimated": "^3.17.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.11.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
