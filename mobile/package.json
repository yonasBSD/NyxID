{
  "name": "nyxid-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "APP_ENV=dev expo start",
    "android": "APP_ENV=dev expo run:android",
    "ios": "APP_ENV=dev expo run:ios",
    "web": "APP_ENV=dev expo start --web",
    "typecheck": "tsc --noEmit",
    "build:ios": "APP_ENV=prod node scripts/build-ios.js",
    "build:ios:dev": "APP_ENV=dev node scripts/build-ios.js",
    "build:android": "APP_ENV=prod node scripts/build-android.js",
    "build:android:dev": "APP_ENV=dev node scripts/build-android.js",
    "build:prod": "pnpm build:ios && pnpm build:android",
    "build:dev": "pnpm build:ios:dev && pnpm build:android:dev",
    "submit:ios": "APP_ENV=prod node scripts/submit-ios.js",
    "submit:android": "APP_ENV=prod node scripts/submit-android.js",
    "submit:prod": "pnpm submit:ios && pnpm submit:android",
    "release:ios": "pnpm build:ios && pnpm submit:ios",
    "release:android": "pnpm build:android && pnpm submit:android",
    "release:prod": "pnpm release:ios && pnpm release:android",
    "bump:ios": "node scripts/bump-version.js ios prod",
    "bump:android": "node scripts/bump-version.js android prod",
    "bump:both": "node scripts/bump-version.js both prod",
    "clean:ios": "node scripts/clean.js ios",
    "clean:android": "node scripts/clean.js android",
    "clean:caches": "node scripts/clean.js caches",
    "clean": "node scripts/clean.js all",
    "clean:full": "node scripts/clean.js full"
  },
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@tanstack/react-query": "^5.96.2",
    "expo": "~55.0.12",
    "expo-blur": "~55.0.13",
    "expo-clipboard": "~55.0.12",
    "expo-dev-client": "~55.0.23",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "^55.0.12",
    "expo-notifications": "~55.0.17",
    "expo-secure-store": "~55.0.12",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.13",
    "expo-web-browser": "~55.0.13",
    "lucide-react-native": "^1.16.0",
    "posthog-react-native": "^4.2.0",
    "punycode": "^2.3.1",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "typescript": "~5.9.3"
  }
}
