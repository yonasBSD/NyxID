{
  "name": "nyxid-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "EXPO_PUBLIC_DEV_MODE=true expo start",
    "android": "EXPO_PUBLIC_DEV_MODE=true expo run:android",
    "ios": "EXPO_PUBLIC_DEV_MODE=true expo run:ios",
    "ios:prod": "EXPO_PUBLIC_API_BASE_URL=https://nyx-api.chrono-ai.fun/api/v1 expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "bump:android:build": "sh scripts/bump-android-build.sh",
    "build:ios": "EXPO_PUBLIC_API_BASE_URL=https://nyx-api.chrono-ai.fun/api/v1 expo run:ios --configuration Release",
    "bump:ios:build": "sh scripts/bump-ios-build.sh",
    "build:ios:testflight": "pnpm run bump:ios:build && grep -q 'EXPO_PUBLIC_API_BASE_URL' ios/.xcode.env.local 2>/dev/null || echo 'export EXPO_PUBLIC_API_BASE_URL=https://nyx-api.chrono-ai.fun/api/v1' >> ios/.xcode.env.local && xcodebuild -workspace ios/NyxIDMobile.xcworkspace -scheme NyxIDMobile -configuration Release -destination 'generic/platform=iOS' -archivePath ios/build/NyxIDMobile.xcarchive -allowProvisioningUpdates archive",
    "eas-build-post-install": "node scripts/patch-android-build-gradle.js"
  },
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@tanstack/react-query": "^5.96.2",
    "expo": "~55.0.12",
    "expo-blur": "~55.0.13",
    "expo-clipboard": "~55.0.12",
    "expo-dev-client": "~55.0.23",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "^55.0.12",
    "expo-notifications": "~55.0.17",
    "expo-secure-store": "~55.0.12",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.13",
    "expo-web-browser": "~55.0.13",
    "posthog-react-native": "^4.2.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~5.9.3"
  }
}
