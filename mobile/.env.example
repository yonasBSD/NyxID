# ============================================================
# NyxID Mobile — env reference (OSS-friendly)
# ------------------------------------------------------------
# Copy this file to one or both of:
#   mobile/.env.dev   (used when APP_ENV=dev)
#   mobile/.env.prod  (used when APP_ENV=prod)
# And/or mobile/.env.local for machine-specific overrides.
#
# Per-field bidirectional fallback (applied by scripts/lib/load-env.js):
#   - Active profile's field empty → falls back to other profile.
#   - Both DEV_API_BASE_URL and PROD_API_BASE_URL empty → build aborts loudly.
#   - Same for IOS_BUNDLE_ID and ANDROID_PACKAGE.
# ============================================================


# === DEV profile ===
DEV_API_BASE_URL=                    # e.g. https://dev.your-api.example.com/api/v1
DEV_IOS_BUNDLE_ID=                   # reverse-DNS, e.g. com.example.myapp.dev
DEV_ANDROID_PACKAGE=                 # reverse-DNS, e.g. com.example.myapp.dev
DEV_APPLE_ASC_APP_ID=                # numeric ASC App ID for the dev iOS app
DEV_IOS_BUILD_NUMBER=                # int, bump per release (or use `pnpm bump:ios`)
DEV_ANDROID_VERSION_CODE=            # int, bump per release (or use `pnpm bump:android`)
DEV_UNIVERSAL_LINK_HOST=             # optional, e.g. dev.yourapp.onelink.me
DEV_UNIVERSAL_LINK_PATH_PREFIX=      # optional, requires HOST set
DEV_LEGAL_BASE_URL=                  # origin where privacy/terms .md are hosted, e.g. https://dev.yourapp.com
DEV_ALLOWED_EMAILS=                  # comma-separated; empty = allow all
DEV_TELEMETRY_DSN=                   # PostHog DSN; empty = telemetry off
DEV_TELEMETRY_HOST=                  # PostHog host URL
DEV_SHARE_ANALYTICS=false


# === PROD profile ===
PROD_API_BASE_URL=                   # e.g. https://nyx-api.chrono-ai.fun/api/v1
PROD_IOS_BUNDLE_ID=                  # reverse-DNS, e.g. fun.chrono-ai.nyxid
PROD_ANDROID_PACKAGE=                # reverse-DNS, e.g. fun.chronoai.nyxid
PROD_APPLE_ASC_APP_ID=               # numeric ASC App ID for the prod iOS app
PROD_IOS_BUILD_NUMBER=               # int; for NyxID start at 35 (last TestFlight build was 34)
PROD_ANDROID_VERSION_CODE=           # int; bump for every Play release
PROD_UNIVERSAL_LINK_HOST=            # optional, e.g. nyxid.onelink.me
PROD_UNIVERSAL_LINK_PATH_PREFIX=     # optional, e.g. /REzJ
PROD_LEGAL_BASE_URL=                 # origin where privacy/terms .md are hosted, e.g. https://nyx.chrono-ai.fun
PROD_ALLOWED_EMAILS=
PROD_TELEMETRY_DSN=
PROD_TELEMETRY_HOST=
PROD_SHARE_ANALYTICS=false


# ============================================================
# App identity (single values, same for dev and prod)
# ============================================================
APP_NAME=NyxID Mobile                # display name on device home screen
APP_SLUG=nyxid-mobile                # used by `npx expo` (URL-safe)
APP_SCHEME=nyxid                     # custom URL scheme (nyxid://...)
APP_VERSION=1.0.1                    # marketing version (CFBundleShortVersionString)


# ============================================================
# iOS build / submit credentials
# ============================================================
APPLE_ID=                            # your Apple Developer account email
APPLE_TEAM_ID=                       # 10 chars uppercase+digits; Apple → Membership
ASC_API_KEY_ID=                      # 10 chars; ASC → Users and Access → Integrations
ASC_API_KEY_ISSUER_ID=               # UUID, same screen as Key ID
# Place the .p8 key file at: mobile/credentials/asc-api-key.p8


# ============================================================
# Android build / submit credentials
# ============================================================
# Keystore (generate ONCE per app, then save+back-up. Losing this locks you
# out of updating the app on Play Console permanently):
#   keytool -genkeypair -v -storetype PKCS12 \
#     -keystore mobile/credentials/release.keystore \
#     -alias nyxid -keyalg RSA -keysize 2048 -validity 10000
ANDROID_KEYSTORE_PATH=./credentials/release.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
# Place the Play service account JSON at:
#   mobile/credentials/play-service-account.json
# (Play Console → Setup → API access → "Release manager" role + app access)
